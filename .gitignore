# Visual Studio 2026 C++ Console Project .gitignore
# ---------------------------------------------------
# Documents which files and folders to ignore in source control

# -----------------------------------------------------------------------------
# Build output directories and object files
# -----------------------------------------------------------------------------
/Debug/
/Release/
x64/
x86/
*.obj
*.exe
*.dll
*.lib
*.pdb

# -----------------------------------------------------------------------------
# Visual Studio user-specific files and folders
# -----------------------------------------------------------------------------
*.user
*.suo
*.userosscache
*.sln.docstates
*.VC.db
*.VC.opendb
*.vcxproj
*.vcxproj.filters

# -----------------------------------------------------------------------------
# Auto-generated files by build process, database, and cache
# -----------------------------------------------------------------------------
ipch/
*.log
*.tlog
*.lastbuildstate

# -----------------------------------------------------------------------------
# CMake generated files and folders (if you're using CMake)
# -----------------------------------------------------------------------------
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile

# -----------------------------------------------------------------------------
# Visual Studio backup, temp, and crash files
# -----------------------------------------------------------------------------
*.tmp
*.bak
*.old
*.sdf

# -----------------------------------------------------------------------------
# NuGet packages folder and build results (sometimes projects use NuGet)
# -----------------------------------------------------------------------------
packages/
*.nupkg
*.snupkg

# -----------------------------------------------------------------------------
# Newtonsoft cache and VS generated tools
# -----------------------------------------------------------------------------
.vs/
.vscode/
*.VC.db
*.VC.VC.db

# -----------------------------------------------------------------------------
# Include environment config files (optional)
# -----------------------------------------------------------------------------
*.userprefs

# -----------------------------------------------------------------------------
# Exclude your own documentation or configuration by removing/commenting below
# -----------------------------------------------------------------------------
# !README.md
# !.gitignore

# -----------------------------------------------------------------------------
# Ignore crash dumps
# -----------------------------------------------------------------------------
*.mdmp
*.dmp

# -----------------------------------------------------------------------------
# C++ compiler auto-generated files
# -----------------------------------------------------------------------------
*.idb
*.pch

# -----------------------------------------------------------------------------
# End of file
# -----------------------------------------------------------------------------
